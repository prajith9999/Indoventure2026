{
  "installCommand": "cd indoventuredoha && npm install",
  "buildCommand": "cd indoventuredoha && npm run build",
  "outputDirectory": "indoventuredoha/dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "redirects": [
    {
      "source": "/cgi-bin",
      "destination": "https://www.indoventuretrading.com/",
      "permanent": true
    },
    {
      "source": "/cgi-bin/:path*",
      "destination": "https://www.indoventuretrading.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.indoventure-trading.com" }],
      "destination": "https://www.indoventuretrading.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "indoventure-trading.com" }],
      "destination": "https://www.indoventuretrading.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "indoventuretrading.com" }],
      "destination": "https://www.indoventuretrading.com/:path*",
      "permanent": true
    }
  ]
}
